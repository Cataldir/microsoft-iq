# Azure credentials
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-microsoft-iq
AZURE_LOCATION=eastus2

# Foundry IQ
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-foundry>.cognitiveservices.azure.com
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=ecommerce-knowledge
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account>
AZURE_STORAGE_CONTAINER_NAME=kaggle-data
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# PostgreSQL (transactional store — bridges Foundry ↔ Fabric)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=microsoftiq
POSTGRES_USER=iqadmin
POSTGRES_PASSWORD=
# Or use a full connection string:
# POSTGRES_CONNECTION_STRING=postgresql://iqadmin:password@localhost:5432/microsoftiq

# Kaggle API (or use ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Work IQ
DATAVERSE_ENVIRONMENT_URL=https://<your-org>.crm.dynamics.com
DATAVERSE_TENANT_ID=

# Fabric IQ
FABRIC_WORKSPACE_NAME=microsoft-iq-demo
FABRIC_CAPACITY_ID=
